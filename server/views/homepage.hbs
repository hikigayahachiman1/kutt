export default {
  async fetch(request) {
    const url = new URL(request.url);
    
    // Homepage → tampilkan iFrame cloaking
    if (url.pathname === '/' || url.pathname === '') {
      return new Response(`
        <!DOCTYPE html>
        <html>
        <head>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1">
          <title>pasticuan.me</title>
          <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            html, body { width: 100%; height: 100%; overflow: hidden; }
            iframe { width: 100%; height: 100%; border: none; display: block; }
          </style>
        </head>
        <body>
          <iframe 
            src="https://pengen-tau-ya.vercel.app/"
            allowfullscreen
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups">
          </iframe>
        </body>
        </html>
      `, {
        headers: { 'Content-Type': 'text/html; charset=utf-8' }
      });
    }
    
    // Semua path lain → redirect ke KuttLink
    const kuttUrl = new URL(request.url);
    kuttUrl.hostname = 'kutt-4sm7onrender.com';
    kuttUrl.protocol = 'https:';
    
    return Response.redirect(kuttUrl.toString(), 302);
  }
}
